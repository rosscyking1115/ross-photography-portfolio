---
import Base from "../layouts/Base.astro";
---

<Base title="Contact" description="Get in touch about prints, exhibitions, or commissions.">
  <section class="mx-auto max-w-screen-2xl px-6 pb-20 pt-14 md:px-10 md:pt-20">
    <p class="eyebrow">Contact</p>
    <h1 class="mt-3 font-[family-name:var(--font-display)] text-5xl tracking-tight md:text-6xl">
      Say hello.
    </h1>

    <div class="mt-12 grid grid-cols-1 gap-16 md:grid-cols-[minmax(0,2fr)_1fr] md:gap-20">
      <form
        id="contact-form"
        method="POST"
        action="/api/contact"
        class="space-y-6"
        novalidate
      >
        <div>
          <label for="name" class="eyebrow block">Name</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class="mt-2 w-full border-0 border-b border-[var(--color-rule)] bg-transparent py-2 text-lg focus:border-[var(--color-ink)] focus:outline-none"
          />
        </div>
        <div>
          <label for="email" class="eyebrow block">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="mt-2 w-full border-0 border-b border-[var(--color-rule)] bg-transparent py-2 text-lg focus:border-[var(--color-ink)] focus:outline-none"
          />
        </div>
        <div>
          <label for="message" class="eyebrow block">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="mt-2 w-full resize-none border-0 border-b border-[var(--color-rule)] bg-transparent py-2 text-lg focus:border-[var(--color-ink)] focus:outline-none"
          ></textarea>
        </div>

        <!-- Honeypot: bots fill it, humans don't see it -->
        <input
          type="text"
          name="company"
          tabindex="-1"
          autocomplete="off"
          class="absolute left-[-9999px]"
          aria-hidden="true"
        />

        <!-- Turnstile widget (Cloudflare). Set CF_TURNSTILE_SITE_KEY in Pages env. -->
        <div class="cf-turnstile" data-sitekey="YOUR_TURNSTILE_SITE_KEY"></div>

        <button
          type="submit"
          class="mt-4 inline-flex items-center gap-2 border border-[var(--color-ink)] bg-[var(--color-ink)] px-7 py-3 text-sm uppercase tracking-[var(--tracking-eyebrow)] text-[var(--color-paper)] transition hover:bg-transparent hover:text-[var(--color-ink)]"
        >
          Send
        </button>

        <p id="form-status" class="text-sm text-[var(--color-muted)]" aria-live="polite"></p>
      </form>

      <aside class="space-y-4 text-[var(--color-ink-2)]">
        <p class="font-[family-name:var(--font-display)] text-xl">Or just email me directly.</p>
        <p>
          <a href="mailto:hello@example.com" class="underline underline-offset-4">hello@example.com</a>
        </p>
        <p class="eyebrow !mt-10">Find me</p>
        <ul class="space-y-1">
          <li><a href="https://instagram.com" rel="noopener noreferrer me" class="underline underline-offset-4">Instagram</a></li>
          <li><a href="https://are.na" rel="noopener noreferrer me" class="underline underline-offset-4">Are.na</a></li>
        </ul>
      </aside>
    </div>
  </section>

  <script
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>
  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const status = document.getElementById("form-status");
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form || !status) return;
      status.textContent = "Sending…";
      const data = new FormData(form);
      try {
        const res = await fetch(form.action, { method: "POST", body: data });
        if (res.ok) {
          form.reset();
          status.textContent = "Thanks — I'll be in touch soon.";
        } else {
          status.textContent = "Something went wrong. Try again or email me directly.";
        }
      } catch {
        status.textContent = "Network error. Try again or email me directly.";
      }
    });
  </script>
</Base>
