---
import Base from "../layouts/Base.astro";
---

<Base title="Not found" description="The page you're looking for doesn't exist.">
  <section class="mx-auto flex min-h-[60dvh] max-w-screen-2xl flex-col items-start justify-center px-6 md:px-10">
    <p class="eyebrow">404</p>
    <h1 class="mt-3 font-[family-name:var(--font-display)] text-6xl tracking-tight md:text-8xl">
      Lost the trail.
    </h1>
    <p class="prose-narrow mt-5 text-lg text-[var(--color-ink-2)]">
      That page doesn't exist — try the
      <a href="/galleries" class="underline underline-offset-4">galleries</a> or head
      <a href="/" class="underline underline-offset-4">home</a>.
    </p>
  </section>
</Base>
