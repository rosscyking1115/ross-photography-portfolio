---
import Base from "../layouts/Base.astro";
---

<Base title="About" description="About Ross — photographer working primarily in landscape and long-form documentary projects.">
  <section class="mx-auto max-w-screen-2xl px-6 pb-20 pt-14 md:px-10 md:pt-20">
    <p class="eyebrow">About</p>
    <h1 class="mt-3 font-[family-name:var(--font-display)] text-5xl tracking-tight md:text-6xl">
      A few words.
    </h1>

    <div class="mt-12 grid grid-cols-1 gap-12 md:grid-cols-[1fr_minmax(0,2fr)] md:gap-20">
      <aside class="space-y-6">
        <div class="aspect-[4/5] w-full max-w-sm bg-[var(--color-paper-2)]"></div>
        <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-3 text-sm">
          <dt class="eyebrow">Based in</dt>
          <dd>—</dd>
          <dt class="eyebrow">Working since</dt>
          <dd>20—</dd>
          <dt class="eyebrow">Email</dt>
          <dd><a href="mailto:hello@example.com" class="underline underline-offset-4">hello@example.com</a></dd>
        </dl>
      </aside>

      <div class="prose-narrow space-y-5 text-lg leading-relaxed text-[var(--color-ink-2)]">
        <p>
          I'm Ross — a photographer drawn to quiet places and slow light.
          My work sits between landscape and long-form documentary, usually
          built across multiple visits to the same place over a year or two.
        </p>
        <p>
          Recent projects include a series along the southern coast of
          Iceland, an ongoing study of inland fog, and a long collaboration
          with a small fishing community on the North Sea.
        </p>
        <p>
          Prints are available on request — get in touch via the
          <a href="/contact" class="underline underline-offset-4">contact page</a>.
        </p>

        <h2 class="!mt-12 !font-[family-name:var(--font-display)] !text-2xl !tracking-tight">Selected exhibitions</h2>
        <ul class="space-y-2 text-base">
          <li>2025 — <em>Northern Greys</em>, solo, Gallery Name, City</li>
          <li>2024 — <em>Group Show Title</em>, group, Venue, City</li>
          <li>2023 — <em>Project Title</em>, solo, Venue, City</li>
        </ul>

        <h2 class="!mt-10 !font-[family-name:var(--font-display)] !text-2xl !tracking-tight">Selected publications</h2>
        <ul class="space-y-2 text-base">
          <li>Magazine Name — feature, Issue 12</li>
          <li>Magazine Name — portfolio, Issue 09</li>
        </ul>
      </div>
    </div>
  </section>
</Base>
